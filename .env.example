# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL RDS connection
DB_HOST=your-db-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# CORS (comma-separated list; "*" for all)
API_CORS_ORIGINS=*

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_ENABLED=true
FROM_EMAIL=your-email@gmail.com

# Twilio (legacy SMS — optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_CUSTOM_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_ENABLED=false
TWILIO_SMS_ENABLED=false
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=visitor-selfie-image

# Meta WhatsApp Business API
Whatsapp_access_token=your_whatsapp_access_token
Whatsapp_number_id=your_whatsapp_phone_number_id
WHATSAPP_ENABLED=true

# Frontend URL
FRONTEND_URL=https://your-frontend-url.com
DASHBOARD_URL=https://your-frontend-url.com/dashboard
